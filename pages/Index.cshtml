<!-- HERO -->
<main class="hero">

        <!-- FILA: logo | separador | título -->
    <div class="hero-header">
        <div class="logo-container">
            <div class="logo-glow"></div>
            <img src="~/images/tot_mallorca_logo.png" alt="Tot Mallorca" />
        </div>
        <div class="header-divider"></div>
        <div class="hero-title-block">
            <div class="main-title" aria-label="Tot Mallorca">
                <span class="title-t">T</span><span class="title-ot">OT</span><span class="title-m"> M</span><span class="title-al">AL</span><span class="title-l">L</span><span class="title-or">OR</span><span class="title-c">C</span><span class="title-a">A</span>
            </div>
            <p class="subtitle">Sa Roqueta a ses teves màns</p>
            <p class="ornament">— ✦ —</p>
        </div>
    </div>

    <!-- POEMA centrado, una columna -->
    <div class="hero-poem">
        <div class="poem-box">
            <p class="poem-header">Ai! Mallorca el cor m'encises</p>
            <ul class="poem-lines">
                <li>Ai! Mallorca el cor m'encises</li>
                <li>Amb ton blau del cel tan bell</li>
                <li>Amb tes platjes remoroses</li>
                <li>Que escomou l'ambat lleuger</li>
                <li>Amb les flors de tes praderes</li>
                <li>Amb lo cant de los aucells</li>
                <li>De los cel é el paradis</li>
                <li>Per a mi semblança n'ets</li>
                <li class="gap">Ai! Mallorca si te deixo,</li>
                <li>D'anyorança moriré.</li>
                <li>Bella terra n'es Mallorca,</li>
                <li>Q'es Mallorca ric verger.</li>
            </ul>
            <p class="poem-author">— Tomàs Forteza</p>
        </div>
    </div>

</main>

<script>
    function toggleSubmenu(id) {
        const panel = document.getElementById(id);
        const allPanels = document.querySelectorAll('.submenu-panel');
        if (panel.style.display === 'block') {
            panel.style.display = 'none';
        } else {
            allPanels.forEach(p => p.style.display = 'none');
            panel.style.display = 'block';
        }
    }
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.top-nav') && !e.target.closest('.submenu-panel')) {
            document.querySelectorAll('.submenu-panel').forEach(p => p.style.display = 'none');
        }
    });
</script>
