    <script>
        // Función para alternar la visibilidad del submenú 
        function toggleSubmenu(id) {
            // Seleccionar el submenú correspondiente
            const submenu = document.getElementById(id);

            // Verificar si el submenú ya está visible
            if (submenu.style.display === 'block') {
                // Si está visible, ocultarlo
                submenu.style.display = 'none';
            } else {
                // Ocultar todos los submenús
                document.querySelectorAll('.submenu-box').forEach(function (submenu) {
                    submenu.style.display = 'none';
                });
                // Mostrar el submenú seleccionado
                submenu.style.display = 'block';
            }
        }
    </script>

   
