<style>
    /* Asegura que el body ocupe toda la altura de la ventana */
    body {
        margin: 0; /* Elimina el margen predeterminado */
        padding: 0; /* Elimina el relleno predeterminado */
        position: relative; /* Hace que el body sea el contenedor para posicionar el recuadro */
        height: 98vh; /* Altura del body al 100% de la ventana */
        /*width: 184vh;*/
    }

    /* Estilo para el recuadro */
    .recuadro {
        border: 5px solid #3498DB; /* Borde azul */
        padding: 20px; /* Espaciado interno */
        background-color: rgba(0, 0, 0, 0.3); /* Fondo */
        border-radius: 8px; /* Bordes redondeados */
        width: 30%; /* Ancho del recuadro */
        text-align: center; /* Alinea el texto dentro del recuadro */
        position: absolute; /* Posiciona el recuadro de forma absoluta */
        bottom: 0; /* Coloca el recuadro en el fondo */
        left: 50%; /* Centra el recuadro horizontalmente */
        transform: translateX(-50%); /* Ajuste para centrar completamente el recuadro */
        line-height: 1; /* Ajusta el espaciado entre líneas */
        
    }
</style>

