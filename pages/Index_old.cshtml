<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menú Lateral Desplegable</title>
    <style>
        /* Estilos básicos para el body */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            display: flex;
        }
        /* Menú lateral derecho */
        .interactivo {
            width: 250px;
            background-color: rgba(0, 0, 0, 0.3);
            border: 2px solid #3498DB;
            border-radius: 8px;
            height: auto; /* Altura completa de la ventana */
            width: auto; /* Ancho del menú lateral */
            position: fixed; /* Fijado al lado derecho */
            right: 0; /* Coloca el menú en el lado derecho */
            padding-top: 20px;
        }
        /* Enlaces del menú */
        .interactivo a {
            display: block;
            color: #fff;
            padding: 10px 20px;
            text-decoration: none;
            font-family: Georgia;
            line-height: 0.3; /* Ajusta el espaciado entre líneas */
        }

        .interactivo a:hover {
            background-color: #575757; /* Color al pasar el mouse */
        }
        /* Contenido principal */
        .main-content {
            margin-right: 250px; /* Empuja el contenido hacia la izquierda para evitar el menú */
            padding: 20px;
            width: calc(100% - 250px); /* Ajusta el ancho para el contenido */
        }

        /* Estilo para el menú lateral */
        .sidebar {
            height: auto; /* Ocupa toda la altura de la pantalla */
            width: auto; /* Ancho del menú lateral */
            background-color: rgba(0, 0, 0, 0.3); /* Color de fondo */
            border: 2px solid #3498DB;
            border-radius: 8px;
            position: fixed; /* Fijo en la pantalla */
            padding-top: 20px;
            color: white;
            top: 20; /* Pegado al borde superior */
            left: 0; /* Pegado al borde izquierdo */
            
        }

        /* Estilos de los items del menú */
        .sidebar a {
            padding: 15px 20px;
            text-decoration: none;
            font-size: 18px;
            color: white;
            display: block;
            position: relative;
            cursor: pointer;
            line-height: 0.3; /* Ajusta el espaciado entre líneas */
            font-family: Georgia;
        }

        .sidebar a:hover {
            background-color: #2980B9; /* Cambio de color al pasar el mouse */
        }

        /* Estilos para el recuadro del submenú */
        .submenu-box {
            margin-left: 205px; /* Posición a la derecha del menú principal */
            width: auto; /* Ancho del recuadro del submenú */
            background-color: #5DADE2;
            position: fixed;
            top: 15;
            left: 20px;
            height: auto;
            padding-top: 20px;
            color: white;
            display: none; /* Oculto por defecto */
            max-height: 300px; /* Establece la altura máxima del contenedor */
            overflow-y: auto; /* Activa el scroll vertical */
        }

        .submenu-box a {
            font-size: 16px;
            font-family: Georgia;
            padding: 10px 20px;
            display: block;
            color: white;
            text-decoration: none;
            line-height: 0.3; /* Ajusta el espaciado entre líneas */
        }

        .submenu-box a:hover {
            background-color: #3498DB; /* Color al pasar el mouse en submenú */
            
        }
    </style>
</head>
