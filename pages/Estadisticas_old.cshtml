<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:wght@400;500&display=swap');

    :root {
        --gold: #C9A84C;
        --gold-light: #E8C97A;
        --gold-dark: #8B6914;
        --crimson: #8B1A1A;
        --deep-blue: #0A1628;
        --cream: #F5EDD6;
        --col-total: #1a3a5c;
        --col-homes: #1a4a2e;
        --col-dones: #6b1a3a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
        overflow: auto !important;
        height: auto !important;
        min-height: 100% !important;
        background: linear-gradient(160deg, #060e1c 0%, #0d1f3c 50%, #091528 100%);
        background-attachment: fixed;
        font-family: 'EB Garamond', Georgia, serif;
        color: #e8dcc8;
    }

    /* ── PAGE ── */
    .page-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 24px 40px;
    }

    /* ── HEADER ── */
    .page-header {
        text-align: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(201,168,76,0.3);
        position: relative;
    }
    .page-header::after {
        content: '';
        position: absolute; bottom: -1px; left: 20%; right: 20%;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .page-header h1 {
        font-family: 'Cinzel', serif;
        font-size: clamp(20px, 3vw, 32px);
        font-weight: 700;
        letter-spacing: 0.2em;
        color: var(--gold-light);
        text-shadow: 0 0 20px rgba(201,168,76,0.3);
    }
    .page-header h2 {
        font-family: 'Cinzel', serif;
        font-size: clamp(11px, 1.3vw, 14px);
        letter-spacing: 0.3em;
        color: rgba(201,168,76,0.6);
        font-weight: 400;
        margin-top: 6px;
        text-transform: uppercase;
    }
    .ornament { color: var(--gold); opacity: 0.5; font-size: 14px; letter-spacing: 8px; margin-top: 8px; }

    /* ── YEAR SELECTOR ── */
    .year-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .year-controls label {
        font-family: 'Cinzel', serif;
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--gold-light);
        opacity: 0.8;
    }
    .year-btn {
        font-family: 'Cinzel', serif;
        font-size: 11px;
        letter-spacing: 0.1em;
        padding: 6px 14px;
        border: 1px solid rgba(201,168,76,0.3);
        background: rgba(6,14,28,0.6);
        color: var(--gold-light);
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .year-btn:hover, .year-btn.active {
        background: rgba(201,168,76,0.18);
        border-color: var(--gold);
        color: #fff;
    }
    .year-btn.active { font-weight: 700; }

    /* ── TABLE WRAPPER ── */
    .table-wrap {
        overflow-x: auto;
        border-radius: 4px;
        border: 1px solid rgba(201,168,76,0.2);
        box-shadow: 0 4px 30px rgba(0,0,0,0.5);
    }
    .table-wrap::-webkit-scrollbar { height: 5px; }
    .table-wrap::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 2px; }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: clamp(11px, 1.1vw, 13px);
    }

    /* ── SECTION HEADERS ── */
    .th-group {
        font-family: 'Cinzel', serif;
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 10px 8px 6px;
        text-align: center;
        color: #fff;
        border-bottom: 2px solid rgba(255,255,255,0.15);
    }
    .th-group.total { background: var(--col-total); }
    .th-group.homes { background: var(--col-homes); }
    .th-group.dones { background: var(--col-dones); }

    /* ── YEAR SUBHEADERS ── */
    thead tr.subhead th {
        font-family: 'Cinzel', serif;
        font-size: 10px;
        letter-spacing: 0.08em;
        padding: 6px 10px;
        text-align: right;
        color: rgba(255,255,255,0.85);
        border-bottom: 1px solid rgba(255,255,255,0.1);
        white-space: nowrap;
    }
    .th-age { text-align: left !important; color: var(--gold-light) !important; background: rgba(6,14,28,0.8) !important; min-width: 120px; }
    .th-y.total { background: rgba(26,58,92,0.9); }
    .th-y.homes { background: rgba(26,74,46,0.9); }
    .th-y.dones { background: rgba(107,26,58,0.9); }

    /* ── DATA ROWS ── */
    tbody tr {
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.15s ease;
    }
    tbody tr:hover { background: rgba(201,168,76,0.07); }
    tbody tr.total-row { border-top: 2px solid rgba(201,168,76,0.3); background: rgba(201,168,76,0.06); }
    tbody tr.total-row td { font-weight: 600; color: var(--gold-light); }

    td {
        padding: 5px 10px;
        text-align: right;
        color: #d4c9b0;
        font-size: clamp(11px, 1vw, 13px);
        white-space: nowrap;
    }
    td.age-label {
        text-align: left;
        font-family: 'EB Garamond', serif;
        color: #b8a88a;
        background: rgba(6,14,28,0.5);
        padding-left: 14px;
        font-size: clamp(11px, 1vw, 13px);
    }
    td.total { background: rgba(26,58,92,0.25); }
    td.homes { background: rgba(26,74,46,0.2); }
    td.dones { background: rgba(107,26,58,0.2); }

    /* hidden year columns */
    .col-year { transition: opacity 0.3s ease; }
    .col-year.hidden { display: none; }

    /* ── FOOTER ── */
    .table-footer {
        text-align: right;
        margin-top: 14px;
        font-family: 'Cinzel', serif;
        font-size: 10px;
        letter-spacing: 0.15em;
        color: rgba(201,168,76,0.45);
        text-transform: uppercase;
    }

    /* ── BACK LINK ── */
    .back-link {
        display: inline-flex; align-items: center; gap: 6px;
        font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.15em;
        text-transform: uppercase; color: var(--gold-light); text-decoration: none;
        padding: 7px 16px; border: 1px solid rgba(201,168,76,0.25);
        border-radius: 2px; background: rgba(6,14,28,0.6); backdrop-filter: blur(8px);
        transition: all 0.2s ease; margin-bottom: 18px; display: inline-block;
    }
    .back-link:hover { background: rgba(201,168,76,0.12); border-color: var(--gold); color: #fff; }
</style>

