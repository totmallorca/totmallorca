<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imágenes en Margen Izquierdo</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        /* Contenedor general para las imágenes */
        .contenedor {
            position: absolute;
            left: 20px; /* Márgen izquierdo */
            top: 280px; /* Márgen superior */
            display: flex;
            flex-direction: column; /* Alinea las imágenes una encima de la otra */
            gap: 10px; /* Espaciado entre las imágenes */
        }

        /* Estilo de las imágenes */
        .imagen {
            position: relative;
            width: 200px; /* Ajusta el ancho de las imágenes */
            height: auto;
            cursor: pointer; /* Cursor para indicar que es clickeable */
        }

        /* Texto sobre la imagen */
        .texto-sobre-imagen {
            position: absolute;
            top: 50%; /* Centra el texto verticalmente */
            left: 50%; /* Centra el texto horizontalmente */
            transform: translate(-50%, -50%);
            color: white;
            font-size: 1rem;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
            text-align: center;
        }

        /* Contenedor de cada imagen */
        .contenedor-imagen {
            position: relative;
        }

        /* links derechos */
        body {
            font-family: Arial, sans-serif;
        }

        .link-dreta {
            position: absolute;
            top: 280px;
            right: 20px;
            background-color: #007BFF;
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
        }

            .link-dreta:hover {
                background-color: #0056b3;
            }
    </style>
    <script>
        function abrirVentanaImagen(url, anchoDefault, altoDefault) {
            // Crear un objeto de imagen para cargar la imagen y obtener sus dimensiones
            const img = new Image();
            img.src = url;

            img.onload = () => {
                // Obtener las dimensiones reales de la imagen
                const ancho = img.naturalWidth || anchoDefault;
                const alto = img.naturalHeight || altoDefault;

                // Calcular la posición para centrar la ventana emergente
                const left = (window.screen.width / 2) - (ancho / 2);
                const top = (window.screen.height / 2) - (alto / 2);

                // Abrir una nueva ventana centrada con el tamaño de la imagen
                window.open(
                    url,
                    'popup',
                    `width=${ancho},height=${alto},left=${left},top=${top},resizable=no,scrollbars=no`
                );
            };

            img.onerror = () => {
                // Si hay un error al cargar la imagen, abrir la ventana con las dimensiones por defecto
                const left = (window.screen.width / 2) - (anchoDefault / 2);
                const top = (window.screen.height / 2) - (altoDefault / 2);

                window.open(
                    url,
                    'popup',
                    `width=${anchoDefault},height=${altoDefault},left=${left},top=${top},resizable=no,scrollbars=no`
                );
            };
        }
    </script>

</head>
<body>
    <!-- Contenedor general -->
    <div class="contenedor">
        <!-- Primera imagen -->
        <div class="contenedor-imagen">
            <a href="javascript:void(0);"
               onclick="abrirVentanaImagen('/Images/51.jpg', 700, 500)">
                <img src="/Images/51.jpg" alt="Localització de Seon Servera" class="imagen">
                <div class="texto-sobre-imagen">LOCALITZACIO</div>
            </a>
        </div>

        <!-- Segunda imagen -->
        <div class="contenedor-imagen">
            <a href="javascript:void(0);"
               onclick="abrirVentanaImagen('/Images/Servera.png', 700, 500)">
                <img src="/Images/Servera.png" alt="Plano des poble" class="imagen">
                <div class="texto-sobre-imagen">PLANO</div>
            </a>
        </div>
    </div>
</body>

<!-- links derechos -->
<body>
    <a href="@Url.Page("/rutes/rutes_servera")" class="link-dreta">RUTES SENDERISME</a>
</body>

</html>

