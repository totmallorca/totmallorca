@page

@model ServeraModel

<style>
    /* Reinicia los estilos predeterminados del navegador */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html, body {
        width: 100%; /* Ocupa todo el ancho de la ventana */
        height: 100%; /* Ocupa todo el alto de la ventana */
    }
    /* Ejemplo de fondo y contenido */
    body {
        display: flex;
        flex-direction: column;
    }
    /* Estilo para el contenedor de la imagen */
    .servera-container {
        display: flex;
        justify-content: center; /* Centra horizontalmente */
        height: 100%; /* Ocupa toda la altura de la ventana */
    }
    /* Estilo para redimensionar la imagen */
    .escud-servera {
        width: auto; /* Cambia el ancho según tus necesidades */
        height: auto; /* Mantiene la proporción de la imagen */
        max-width: 100px; /* Ajusta el ancho máximo */
        max-height: 100px; /* Ajusta la altura máxima */
    }

    .title {
        margin-top: 20px; /* Espacio entre la imagen y el título */
        font-size: 1.5rem; /* Tamaño del texto */
        color: darkred; /* Color del texto */
        font-family: 'Georgia Pro'; /* Fuente */
        justify-content: center;
        display: flex;
        font-weight: bold;
    }
    /* Estilo para la línea */
    .line {
        width: 100%; /* Ocupa todo el ancho de la página */
        height: 2px; /* Grosor de la línea */
        background-color: #333; /* Color de la línea */
        margin: 20px 0; /* Espaciado arriba y abajo */
    }
</style>
<body>
    <!-- Imagen con clase para ajustarla -->
    <div class="servera-container">
        <img src="/Images/Escudo_de_Son_Servera.png" class="escud-servera">
    </div>
    <div class="title"><u>S O N  &nbsp  S E R V E R A</u></div>
    <div class="line"></div>
</body>
